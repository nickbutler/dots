[user]
  name = Nick Butler
  email = nick@codeindulgence.com
[core]
  excludesfile = ~/.config/git/ignore
  pager = delta
  editor = nvim +start
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true
  light = false
  line-numbers = true
  side-by-side = false
  syntax-theme = Nord
  keep-plus-minus-markers = true
  minus-style = "dim syntax"
  minus-emph-style = "dim bold syntax"
  plus-style = "syntax"
  plus-emph-style = "bold syntax"
  line-numbers-left-format = ""
  line-numbers-right-format = "{np:>4}│ "
  line-numbers-minus-style = "red"
  line-numbers-plus-style = "green"
  line-numbers-zero-style = "#4c566a"
  line-numbers-right-style = "#4c566a"
  file-style = bold blue
  file-decoration-style  = none
  hunk-header-style = omit
[color]
  ui = true
[branch]
  autosetupmerge = always
[push]
  default = simple
  followTags = true
[alias]
  b = branch
  br = branch
  co = checkout
  ci = commit
  st = status -bsu
  check = "!git fetch --all && git st"
  ch = "!git check"
  ignore = "!gi() { curl -L -s https://www.gitignore.io/api/$@ ;}; gi"
  pop = stash pop
  prb = pull --rebase
  prbs = "!git stash; git pull --rebase; git stash pop"
  amend = "commit --amend -C HEAD"
  soft = "reset --soft HEAD^"
  hard = "reset --hard"
  mad = "!git checkout main && git merge - && git branch -d @{-1}"
[credential]
  helper = osxkeychain
[diff]
  compactionHeuristic = true
  colorMoved = default
[merge]
  ff = only
  tool = nvimdiff
  conflictstyle = diff3
[commit]
  gpgSign = true
  template = .git/NEXT_COMMITMSG
[status]
  showUntrackedFiles = all
[tig]
  line-graphics = utf-8
  main-view-author-display = no
  main-view-date-display = relative-compact
  status-show-untracked-files = yes
[tig "bind"]
  status = C !git commit -v
[tig "color"]
  cursor = black magenta
[rebase]
  autoSquash = true
  autoStash = true
[pull]
	rebase = true
[init]
	defaultBranch = main
  templateDir = ~/.config/git/template

[include]
  path = ~/.config/git/config.local

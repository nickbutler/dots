#!/usr/bin/env python3
"""Export Claude Code prompt history to JSON."""

import json
import glob
import os
import sys

OUTPUT = os.path.expanduser("~/claude_prompt_history.json")
SKIP_PREFIXES = ("<local-command-caveat>", "Unknown skill:", "[Request interrupted")


def main():
    files = sorted(glob.glob(os.path.expanduser("~/.claude/projects/**/*.jsonl"), recursive=True))
    prompts = []

    for f in files:
        parts = f.split("/projects/")[1].split("/")
        project = parts[0].replace("-Users-nick-", "", 1).replace("-", "/", 2)
        session = parts[1].replace(".jsonl", "") if len(parts) > 1 else ""
        try:
            for line in open(f, errors="ignore"):
                line = line.strip()
                if not line:
                    continue
                obj = json.loads(line)
                if obj.get("type") != "user":
                    continue
                msg = obj.get("message", {})
                content = msg.get("content", "")
                if isinstance(content, list):
                    text = " ".join(
                        c.get("text", "")
                        for c in content
                        if isinstance(c, dict) and c.get("type") == "text"
                    )
                elif isinstance(content, str):
                    text = content
                else:
                    text = ""
                text = text.strip()
                if not text or any(text.startswith(p) for p in SKIP_PREFIXES):
                    continue
                prompts.append({"project": project, "session": session, "prompt": text})
        except Exception:
            pass

    out = sys.argv[1] if len(sys.argv) > 1 else OUTPUT
    with open(out, "w") as fh:
        json.dump(prompts, fh, indent=2)
    print(f"Wrote {len(prompts)} prompts to {out}")


if __name__ == "__main__":
    main()

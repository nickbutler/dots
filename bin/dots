#!/usr/bin/env fish

set dotfile_dir ~/.config/dotfiles

if not test -d $dotfile_dir
  echo "Dotfiles not found at $dotfile_dir."
  echo "Clone the repo first: git clone https://github.com/nickbutler/dotfiles.git $dotfile_dir"
  exit 1
end

cd $dotfile_dir

function ok
  echo -s (set_color green) "Ok!" (set_color normal)
end

function program_description
  switch $argv[1]
    case bpython;        echo "enhanced Python REPL"
    case efm-langserver; echo "generic LSP server"
    case fd;             echo "fast find alternative"
    case fish;           echo "the shell"
    case git;            echo "version control"
    case markdownlint;   echo "markdown linter"
    case nvim;           echo "Neovim text editor"
    case ranger;         echo "terminal file manager"
    case starship;       echo "minimalist shell prompt"
    case tmux;           echo "terminal multiplexer"
    case '*';            echo ""
  end
end

# Returns the package name for a given program and package manager.
# Empty string means not available via that manager.
function package_name
  set -l program $argv[1]
  set -l manager $argv[2]
  switch $manager
    case brew
      switch $program
        case nvim;           echo neovim
        case efm-langserver; echo efm-langserver
        case markdownlint;   echo markdownlint
        case '*';            echo $program
      end
    case apt-get
      switch $program
        case nvim;           echo neovim
        case fd;             echo fd-find
        case efm-langserver; echo ""
        case markdownlint;   echo ""
        case starship;       echo ""
        case '*';            echo $program
      end
  end
end

function symlink_one
  set -l source (realpath $argv[1])
  set -l dest $argv[2]

  if test -L $dest; and test (realpath $dest 2>/dev/null) = $source
    ok
    return
  end

  if test -e $dest; or test -L $dest
    set -l backup_path $dest.(date +%s).dots_backup
    echo -n -s (set_color yellow) "Backing up: $backup_path. "
    mv $dest $backup_path
  end

  ln -sf $source $dest
  ok
end

function symlink_configs
  echo "Configs:"
  for program_path in $dotfile_dir/config/*
    set -l program (basename $program_path)
    if type $program > /dev/null 2>&1
      echo -n "  $program: "
      symlink_one $program_path ~/.config/$program
    else
      echo -n "  $program: "
      echo -s (set_color yellow) "Skipped (not installed)." (set_color normal)
    end
  end
  echo
end

function symlink_bin
  mkdir -p ~/.local/bin
  echo "Bin scripts:"
  for script_path in $dotfile_dir/bin/*
    set -l script (basename $script_path)
    echo -n "  $script: "
    symlink_one $script_path ~/.local/bin/$script
  end
  echo
end

function symlink_others
  set -l state_file $dotfile_dir/.dots_skipped
  set -l skipped
  test -f $state_file; and set skipped (cat $state_file)

  set -l any 0
  for program_path in $dotfile_dir/optional/*/
    set -l program (basename $program_path)
    test -L ~/.config/$program; and continue
    contains -- $program $skipped; and continue
    set any 1
    read -n1 -P "  Link $program? [y/N] " choice < /dev/tty
    echo
    if string match -qi y $choice
      echo -n "  Linking $program: "
      symlink_one $program_path ~/.config/$program
    else
      echo $program >> $state_file
    end
  end
  test $any -eq 1; and echo
end

function offer_install
  set -l manager
  if type brew > /dev/null 2>&1
    set manager brew
  else if type apt-get > /dev/null 2>&1
    set manager apt-get
  else
    return
  end

  set -l packages
  set -l skipped_programs
  for program in $argv
    set -l pkg (package_name $program $manager)
    if test -n "$pkg"
      set -a packages $pkg
    else
      set -a skipped_programs $program
    end
  end

  if test (count $packages) -eq 0
    echo -s (set_color yellow) "No installable packages found via $manager." (set_color normal)
    echo
    return
  end

  echo -s (set_color yellow) "Missing programs:" (set_color normal)
  for program in $argv
    set -l pkg (package_name $program $manager)
    if test -n "$pkg"
      echo "  $program — "(program_description $program)
    end
  end
  if test (count $skipped_programs) -gt 0
    echo
    echo -s (set_color brblack) "  Not available via $manager: "(string join ", " $skipped_programs) (set_color normal)
  end
  echo

  read -n1 -P "Install with $manager? [y/N] " choice < /dev/tty
  echo
  if not string match -qi y $choice
    return
  end

  switch $manager
    case brew
      brew install $packages
    case apt-get
      set -l maybe_sudo
      test (id -u) -ne 0; and set maybe_sudo sudo
      $maybe_sudo apt-get update
      $maybe_sudo apt-get install -y $packages
  end
  echo
end

# Check for updates
echo "Checking for updates..."
git fetch --quiet origin master
set count (git rev-list HEAD..origin/master --count)

if test $count -gt 0
  echo -s (set_color cyan) "$count new commit"(test $count -ne 1; and echo s)(set_color normal) " on master:"
  echo
  git log HEAD..origin/master --oneline --no-decorate | while read -l line
    echo "  $line"
  end
  echo
  read -n1 -P "Pull updates? [y/N] " choice < /dev/tty
  echo
  if string match -qi y $choice
    git pull origin master
    echo
  else
    echo "Skipped."
    echo
  end
else
  echo "Already up to date."
end

# Detect missing programs before linking
set -g missing_programs
for program_path in $dotfile_dir/config/*
  set -l program (basename $program_path)
  type $program > /dev/null 2>&1; or set -a missing_programs $program
end

# Offer to install missing programs before linking so configs get picked up
if test (count $missing_programs) -gt 0
  offer_install $missing_programs
end

symlink_configs
symlink_bin
symlink_others

# Show anything still missing after potential install
set -l still_missing
for program in $missing_programs
  type $program > /dev/null 2>&1; or set -a still_missing $program
end
if test (count $still_missing) -gt 0
  echo -s (set_color yellow) "Not installed:" (set_color normal)
  for program in $still_missing
    echo "  $program — "(program_description $program)
  end
  echo
end

if not contains -- ~/.local/bin $PATH
  echo -s (set_color yellow) "~/.local/bin is not on your PATH." (set_color normal)
  read -n1 -P "Add it now with fish_add_path? [y/N] " choice < /dev/tty
  echo
  if string match -qi y $choice
    fish_add_path ~/.local/bin
    echo "Added. Restart your shell or run 'exec fish' to pick it up."
    echo
  end
end

echo -s (set_color green) "Done." (set_color normal)
